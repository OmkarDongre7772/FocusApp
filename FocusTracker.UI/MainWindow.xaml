<Window x:Class="FocusTracker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Tracker"
        Width="1200"
        Height="760"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>

        <!-- LIGHT DEFAULT THEME -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F4F6FB"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#059669"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#CA8A04"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>

        <!-- Base Text Styles -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Header Text -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Subheader Text -->
        <Style x:Key="SubheaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- KPI Label -->
        <Style x:Key="KpiLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- KPI Value -->
        <Style x:Key="KpiTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Section Title -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Focus Timer Display -->
        <Style x:Key="TimerTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="44"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Card Style with Subtle Shadow Effect -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                      Opacity="0.04" 
                                      BlurRadius="20" 
                                      ShadowDepth="2" 
                                      Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact KPI Card -->
        <Style x:Key="KpiCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                      Opacity="0.03" 
                                      BlurRadius="16" 
                                      ShadowDepth="1" 
                                      Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button (Quick Focus Buttons) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Button -->
        <Style TargetType="ToggleButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border Name="PART_Track"
                                    CornerRadius="4"
                                    ClipToBounds="True">
                                <Border Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Margin" Value="0,16"/>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>

            <Grid Margin="24,24,24,20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="300"/>
                    <RowDefinition Height="Auto" MinHeight="120"/>
                </Grid.RowDefinitions>

                <!-- HEADER SECTION -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Title and Status -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Focus Dashboard"
                               Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock x:Name="LoginStatusText"
                               Style="{StaticResource SubheaderTextStyle}"
                               Margin="0,4,0,0"
                               Text="Not logged in (Local mode)"/>
                    </StackPanel>

                    <!-- Right: Controls -->
                    <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                        <ToggleButton x:Name="ThemeToggle"
                                  Width="90"
                                  Margin="0,0,12,0"
                                  Content="Dark"
                                  Checked="ThemeToggle_Checked"
                                  Unchecked="ThemeToggle_Unchecked"/>

                        <Button x:Name="LoginButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Login"
                            Click="LoginButton_Click"/>
                    </StackPanel>
                </Grid>

                <!-- MAIN CONTENT AREA -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" MinWidth="320"/>
                        <ColumnDefinition Width="1*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT COLUMN: FOCUS SESSION CARD -->
                    <Border Style="{StaticResource CardStyle}" 
                        Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Section Header -->
                            <TextBlock Text="Focus Session"
                                   Style="{StaticResource SectionTitleStyle}"/>

                            <!-- Timer Display Area -->
                            <StackPanel Grid.Row="1" 
                                    VerticalAlignment="Center"
                                    Margin="0,8,0,8">

                                <TextBlock x:Name="FocusStatusText"
                                       Style="{StaticResource TimerTextStyle}"
                                       Text="Inactive"/>

                                <TextBlock x:Name="CountdownText"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"
                                       Text=""/>

                                <ProgressBar x:Name="FocusProgressBar"
                                         Margin="0,0,0,28"
                                         Maximum="100"/>

                            </StackPanel>

                            <!-- Controls Area -->
                            <StackPanel Grid.Row="2">

                                <!-- Quick Duration Buttons -->
                                <TextBlock Text="Quick Start"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,8"/>

                                <UniformGrid x:Name="QuickButtonsGrid"
                                         Columns="4"
                                         Margin="0,0,0,20">
                                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="1m" 
                                        Click="Focus1_Click"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="25m" 
                                        Click="Focus25_Click"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="45m" 
                                        Click="Focus45_Click"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="60m" 
                                        Click="Focus60_Click"/>
                                </UniformGrid>

                                <!-- Primary Action Button -->
                                <Button x:Name="PrimaryFocusButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Start 25 Minute Focus"
                                    Click="PrimaryFocusButton_Click"
                                    Margin="0,0,0,16"/>

                                <!-- Tracking Toggle -->
                                <ToggleButton x:Name="TrackingToggle"
                                          Content="Tracking Enabled"
                                          HorizontalAlignment="Stretch"
                                          Checked="TrackingToggle_Checked"
                                          Unchecked="TrackingToggle_Unchecked"/>

                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- RIGHT COLUMN: KPI METRICS GRID -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="80"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="130"/>
                            <ColumnDefinition Width="*" MinWidth="130"/>
                        </Grid.ColumnDefinitions>

                        <!-- Productivity Score -->
                        <Border Grid.Row="0" Grid.Column="0" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="PRODUCTIVITY SCORE"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="ProductivityScoreText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="0/100"/>
                            </StackPanel>
                        </Border>

                        <!-- Deep Work -->
                        <Border Grid.Row="0" Grid.Column="1" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="DEEP WORK"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="DeepWorkText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="0.0 min"/>
                            </StackPanel>
                        </Border>

                        <!-- Focus Time -->
                        <Border Grid.Row="1" Grid.Column="0" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="FOCUS TIME TODAY"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="FocusTimeText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="0.0 min"/>
                            </StackPanel>
                        </Border>

                        <!-- Average Session -->
                        <Border Grid.Row="1" Grid.Column="1" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="AVG SESSION"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="LongestFocusText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="0.0 min"/>
                            </StackPanel>
                        </Border>

                        <!-- Fragmentation -->
                        <Border Grid.Row="2" Grid.Column="0" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="FRAGMENTATION"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="FragmentationText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="None (0/100)"/>
                            </StackPanel>
                        </Border>

                        <!-- Interruptions -->
                        <Border Grid.Row="2" Grid.Column="1" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="INTERRUPTIONS"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="InterruptText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="0.0 per session"/>
                            </StackPanel>
                        </Border>

                        <!-- Idle Time -->
                        <Border Grid.Row="3" Grid.Column="0" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="IDLE RATIO"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="IdleText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="0%"/>
                            </StackPanel>
                        </Border>

                        <!-- Sessions -->
                        <Border Grid.Row="3" Grid.Column="1" 
                            Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="TOTAL SESSIONS"
                                       Style="{StaticResource KpiLabelStyle}"/>
                                <TextBlock x:Name="AppSwitchesText" 
                                       Style="{StaticResource KpiTextStyle}"
                                       Text="Sessions: 0"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>

                <!-- BOTTOM SECTION: WEEKLY PERFORMANCE -->
                <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Margin="0,16,0,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Section Title -->
                        <TextBlock Grid.Row="0" 
                               Grid.ColumnSpan="2"
                               Text="Weekly Performance"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,0,0,16"/>

                        <!-- Weekly Summary -->
                        <StackPanel Grid.Row="1" Grid.Column="0"
                                Margin="0,0,20,0">
                            <TextBlock x:Name="WeeklyText" 
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   Text="0.0 min/day  |  Streak: 0 days"/>
                        </StackPanel>

                        <!-- Completion Trend -->
                        <StackPanel Grid.Row="1" Grid.Column="1"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="CompletionTrendText"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="Trend: Stable"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Separator Grid.Row="2" 
                               Grid.ColumnSpan="2"
                               Margin="0,20,0,16"/>

                        <!-- Top Distraction -->
                        <StackPanel Grid.Row="3" 
                                Grid.ColumnSpan="2">
                            <TextBlock Text="Top Distraction"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,8"/>

                            <TextBlock x:Name="TopDistractionText"
                                   FontSize="15"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Text="None"/>
                        </StackPanel>

                    </Grid>
                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</Window>
