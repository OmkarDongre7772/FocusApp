<Window x:Class="FocusTracker.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="320"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Notifications -->
        <CheckBox
            x:Name="NudgesCheckBox"
            Content="Enable Notifications"
            FontWeight="SemiBold"
            Grid.Row="0"
            Margin="0,0,0,15"/>

        <!-- Sensitivity -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Fragmentation Sensitivity"/>
            <ComboBox x:Name="SensitivityCombo" Margin="0,5,0,0">
                <ComboBoxItem Content="Strict"/>
                <ComboBoxItem Content="Balanced"/>
                <ComboBoxItem Content="Relaxed"/>
            </ComboBox>
        </StackPanel>

        <!-- Focus Praise -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Focus praise after (minutes)"/>
            <TextBox x:Name="FocusMinutesBox" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Max Notifications -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Max notifications per hour"/>
            <TextBox x:Name="MaxNotifBox" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Save Button -->
        <Button
            Grid.Row="5"
            Content="Save"
            Width="100"
            Height="32"
            HorizontalAlignment="Center"
            Click="Save_Click"/>
    </Grid>
</Window>
