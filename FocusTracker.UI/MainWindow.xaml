<Window x:Class="FocusTracker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        Title="Focus Tracker"
        Height="520"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="#F5F7FA" Padding="20">

        <StackPanel>

            <!-- HEADER -->
            <TextBlock Text="Focus Tracker"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="LoginStatusText"
               VerticalAlignment="Center"
               FontWeight="SemiBold"/>
                <Button x:Name="LoginButton"
            Content="Login"
            Width="80"
            Margin="10,0,0,0"
            Click="LoginButton_Click"/>
            </StackPanel>


            <!-- FOCUS STATUS -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,0,15">

                <StackPanel>

                    <TextBlock Text="Focus Mode"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="FocusStatusText"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,5,0,5"/>

                    <ProgressBar x:Name="FocusProgressBar"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"/>

                    <ToggleButton x:Name="TrackingToggle"
                              Content="Tracking Enabled"
                              Margin="0,10,0,0"
                              Height="30"
                              Checked="TrackingToggle_Checked"
                              Unchecked="TrackingToggle_Unchecked"/>


                    <TextBlock x:Name="CountdownText"
                               FontSize="14"
                               Margin="0,5,0,0"
                               Foreground="DarkGreen"/>

                </StackPanel>
            </Border>

            <!-- TODAY SUMMARY -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,0,15">

                <StackPanel>
                    <TextBlock Text="Today's Analytics"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="AppSwitchesText" Margin="0,3"/>
                    <TextBlock x:Name="FocusTimeText" Margin="0,3"/>
                    <TextBlock x:Name="LongestFocusText" Margin="0,3"/>
                    <TextBlock x:Name="FragmentationText" Margin="0,3"/>
                    <TextBlock x:Name="InterruptText" Margin="0,3"/>
                    <TextBlock x:Name="IdleText" Margin="0,3"/>
                </StackPanel>
            </Border>

            <!-- WEEKLY -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="15">

                <StackPanel>
                    <TextBlock Text="7-Day Performance"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="WeeklyText"/>
                    <TextBlock x:Name="CompletionTrendText" Margin="0,3"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</Window>
