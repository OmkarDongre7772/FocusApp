{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },
    "Fragmentation": {
        "IdleWeight": 0.4,
        "InterruptWeight": 0.4,
        "EarlyStopWeight": 0.2,
        "MaxInterruptThreshold": 20,
        "MaxIdleThresholdSeconds": 900
    }
}
