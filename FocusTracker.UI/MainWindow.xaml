<Window x:Class="FocusTracker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Tracker"
        Height="220"
        Width="300"
        ShowInTaskbar="False"
        WindowState="Minimized">

    <StackPanel Margin="20">

        <TextBlock
            Text="Today's Summary"
            FontSize="18"
            FontWeight="Bold"
            Margin="0,0,0,10"/>

        <TextBlock
            x:Name="AppSwitchesText"
            FontSize="14"
            Margin="0,5"/>

        <TextBlock
            x:Name="FocusTimeText"
            FontSize="14"
            Margin="0,5"/>

        <TextBlock
    x:Name="LongestFocusText"
    FontSize="14"
    Margin="0,5"/>

        <TextBlock
    x:Name="NotificationStatusText"
    FontSize="13"
    Margin="0,15,0,0"
    Foreground="Gray"/>

        <TextBlock
    Text="Suggestions"
    FontSize="16"
    FontWeight="Bold"
    Margin="0,15,0,5"/>

        <ItemsControl x:Name="SuggestionsList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,5">
                        <TextBlock
                    Text="{Binding Title}"
                    FontWeight="SemiBold"/>
                        <TextBlock
                    Text="{Binding Message}"
                    FontSize="13"
                    Foreground="Gray"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock
    x:Name="WeeklyText"
    FontSize="13"
    Margin="0,10,0,0"
    Foreground="DarkSlateGray"/>

        <TextBlock
    x:Name="FragmentationText"
    FontSize="14"
    Margin="0,10,0,0"/>

        <TextBlock
    Text="Focus Mode Stats"
    FontSize="16"
    FontWeight="Bold"
    Margin="0,15,0,5"/>

        <TextBlock x:Name="FocusStatsText"
           FontSize="13"
           Foreground="DarkSlateGray"/>

    </StackPanel>
</Window>