<Window x:Class="FocusTracker.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account"
        MinHeight="420"
        MinWidth="360"
        Width="420"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI">

	<Window.Resources>

		<!-- Accent -->
		<SolidColorBrush x:Key="AccentBrush" Color="#4F46E5"/>

		<!-- Card -->
		<Style x:Key="CardStyle" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Padding" Value="24"/>
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.12"/>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Primary Button -->
		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Background" Value="{StaticResource AccentBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="MinHeight" Value="36"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Secondary Button -->
		<Style x:Key="SecondaryButton" TargetType="Button">
			<Setter Property="Background" Value="#E5E7EB"/>
			<Setter Property="Foreground" Value="#111827"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="MinHeight" Value="34"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- TextBox -->
		<Style TargetType="TextBox">
			<Setter Property="Padding" Value="8"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<!-- PasswordBox -->
		<Style TargetType="PasswordBox">
			<Setter Property="Padding" Value="8"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

	</Window.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">

		<Grid Margin="28" MaxWidth="600">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Header -->
			<StackPanel Grid.Row="0" Margin="0,0,0,24">
				<TextBlock Text="Welcome Back"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#111827"/>

				<TextBlock Text="Login to sync your focus analytics to the cloud."
                           Margin="0,6,0,0"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"/>
			</StackPanel>

			<!-- Card -->
			<Border Grid.Row="1"
                    Style="{StaticResource CardStyle}">

				<StackPanel>

					<!-- Email -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="Email"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
						<TextBox x:Name="EmailBox"
                                 Margin="0,6,0,0"/>
					</StackPanel>

					<!-- Password -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="Password"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
						<PasswordBox x:Name="PasswordBox"
                                     Margin="0,6,0,0"/>
					</StackPanel>

					<!-- Team ID -->
					<StackPanel Margin="0,0,0,20">
						<TextBlock Text="Team ID (optional)"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
						<TextBox x:Name="TeamBox"
                                 Margin="0,6,0,0"/>
					</StackPanel>

					<!-- Buttons -->
					<StackPanel>
						<Button Content="Login"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,10"
                                Click="Login_Click"/>

						<Button Content="Create Account"
                                Style="{StaticResource SecondaryButton}"
                                Click="Register_Click"/>
					</StackPanel>

				</StackPanel>

			</Border>

		</Grid>

	</ScrollViewer>

</Window>
