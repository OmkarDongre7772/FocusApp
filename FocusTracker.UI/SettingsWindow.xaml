<Window x:Class="FocusTracker.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="300"
        Width="350"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">

        <CheckBox
            x:Name="NudgesCheckBox"
            Content="Enable notifications" RenderTransformOrigin="0.764,0.551"
            />

        <TextBlock Text="Fragmentation sensitivity" />
        <ComboBox x:Name="SensitivityCombo" Margin="0,5,0,10">
            <ComboBoxItem Content="Strict" Tag="1"/>
            <ComboBoxItem Content="Balanced" Tag="2"/>
            <ComboBoxItem Content="Relaxed" Tag="3"/>
        </ComboBox>

        <TextBlock Text="Focus praise after (minutes)" />
        <TextBox x:Name="FocusMinutesBox" Margin="0,5,0,10"/>

        <TextBlock Text="Max notifications per hour" />
        <TextBox x:Name="MaxNotifBox" Margin="0,5,0,10"/>

        <Button
            Content="Save"
            Width="80"
            HorizontalAlignment="Center"
            Click="Save_Click" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" ForceCursor="True" FontFamily="Verdana">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="0.85"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
    </StackPanel>
</Window>