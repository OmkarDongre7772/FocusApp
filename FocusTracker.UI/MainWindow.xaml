<Window x:Class="FocusTracker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Tracker"
        MinHeight="500"
        MinWidth="380"
        Width="500"
        Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Accent -->
        <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5"/>

        <!-- Card -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle -->
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- Fully responsive scroll -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid Margin="24"
                  MaxWidth="900">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Focus Tracker"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <TextBlock x:Name="LoginStatusText"
                                   Margin="0,6,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"/>
                    </StackPanel>

                    <!-- Login / Logout Button -->
                    <Button x:Name="LoginButton"
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Content="Login"
                            Click="LoginButton_Click"/>
                </Grid>

                <!-- FOCUS CARD -->
                <Border Grid.Row="1"
                        Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Focus Mode"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"/>

                        <TextBlock x:Name="FocusStatusText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,8,0,10"
                                   Foreground="#111827"/>

                        <ProgressBar x:Name="FocusProgressBar"
                                     Height="14"
                                     Minimum="0"
                                     Maximum="100"
                                     Margin="0,0,0,12"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#E5E7EB"/>

                        <ToggleButton x:Name="TrackingToggle"
                                      Height="38"
                                      Margin="0,0,0,8"
                                      Content="Tracking Enabled"
                                      Checked="TrackingToggle_Checked"
                                      Unchecked="TrackingToggle_Unchecked"/>

                        <TextBlock x:Name="CountdownText"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#10B981"/>
                    </StackPanel>
                </Border>

                <!-- TODAY -->
                <Border Grid.Row="2"
                        Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Today's Analytics"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"
                                   Foreground="#111827"/>

                        <TextBlock x:Name="AppSwitchesText" Margin="0,5"/>
                        <TextBlock x:Name="FocusTimeText" Margin="0,5"/>
                        <TextBlock x:Name="LongestFocusText" Margin="0,5"/>
                        <TextBlock x:Name="FragmentationText" Margin="0,5"/>
                        <TextBlock x:Name="InterruptText" Margin="0,5"/>
                        <TextBlock x:Name="IdleText" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- WEEKLY -->
                <Border Grid.Row="3"
                        Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="7-Day Performance"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"
                                   Foreground="#111827"/>

                        <TextBlock x:Name="WeeklyText" Margin="0,5"/>
                        <TextBlock x:Name="CompletionTrendText"
                                   Margin="0,5"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>

</Window>
